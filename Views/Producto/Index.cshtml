@model IEnumerable<MiPrimerMVC.Models.Producto>
@{
    ViewData["Title"] = "Catalogo de Productos";
}

<div class="container mt-4">
    <h1 class="mb-3">Catalogo de Productos</h1>

    @* Banner de exito mostrado solo tras un redirect exitoso (TempData) *@
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"
             role="alert">
            <strong>&#10004;</strong> @TempData["Exito"]
            <button type="button" class="btn-close"
                    data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <a asp-action="Create" class="btn btn-primary mb-3">
        + Agregar Producto
    </a>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No hay productos registrados aun. Haga clic en
            <strong>Agregar Producto</strong> para comenzar.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Descripcion</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Categoria</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Nombre</td>
                        <td>@p.Descripcion</td>
                        <td>@p.Precio.ToString("C")</td>
                        <td>@p.Stock</td>
                        <td>@p.Categoria</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>